<mujoco model="rm65 + EG2-4C2 scene">
  <compiler angle="radian"/>

  <statistic center="0 0 0.4" extent="1"/>

  <option integrator="implicitfast" cone="elliptic" impratio="10"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-45" elevation="-20"/>
  </visual>

  <default>
    <default class="rm65">
      <default class="rm65/visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2" rgba="0.82 0.82 0.82 1"/>
      </default>
      <default class="rm65/collision">
        <geom type="mesh" group="3"/>
      </default>
      <default class="rm65_actuator">
        <position kp="150" kv="40" forcerange="-100 100"/>
      </default>
    </default>

    <default class="eg2">
      <default class="eg2/visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2" rgba="0.2 0.2 0.2 1"/>
      </default>
      <default class="eg2/collision">
        <geom type="mesh" group="3" friction="1.2 0.05 0.05"/>
      </default>
      <default class="eg2_driver_pos">
        <joint type="hinge" axis="0 -1 0" range="0 0.82" armature="0.005" damping="0.2"/>
      </default>
      <default class="eg2_driver_neg">
        <joint type="hinge" axis="0 -1 0" range="-0.82 0" armature="0.005" damping="0.2"/>
      </default>
    </default>

    <site size="0.001" rgba="0.5 0.5 0.5 0.3" group="4"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.6 0.6 0.6" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.5 0.5 0.5" rgb2="0.3 0.3 0.3"
      markrgb="0.4 0.4 0.4" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <!-- RM65 arm meshes -->
    <mesh name="rm65_base_link" file="../../third_party/rm_models/RM65/urdf/RM65-6F/meshes/base_link.STL"/>
    <mesh name="rm65_link_1"    file="../../third_party/rm_models/RM65/urdf/RM65-6F/meshes/link_1.STL"/>
    <mesh name="rm65_link_2"    file="../../third_party/rm_models/RM65/urdf/RM65-6F/meshes/link_2.STL"/>
    <mesh name="rm65_link_3"    file="../../third_party/rm_models/RM65/urdf/RM65-6F/meshes/link_3.STL"/>
    <mesh name="rm65_link_4"    file="../../third_party/rm_models/RM65/urdf/RM65-6F/meshes/link_4.STL"/>
    <mesh name="rm65_link_5"    file="../../third_party/rm_models/RM65/urdf/RM65-6F/meshes/link_5.STL"/>
    <mesh name="rm65_link_6"    file="../../third_party/rm_models/RM65/urdf/RM65-6F/meshes/link_6.STL"/>

    <!-- Realman EG2-4C2 two-finger electric gripper meshes (meters) -->
    <mesh name="eg2_base"  file="../../third_party/rm_models/thirdparty/Two-finger Electric Gripper.urdf/meshes/4C2_baselink.STL"/>
    <mesh name="eg2_link1" file="../../third_party/rm_models/thirdparty/Two-finger Electric Gripper.urdf/meshes/4C2_Link1.STL"/>
    <mesh name="eg2_link2" file="../../third_party/rm_models/thirdparty/Two-finger Electric Gripper.urdf/meshes/4C2_Link2.STL"/>
    <mesh name="eg2_link3" file="../../third_party/rm_models/thirdparty/Two-finger Electric Gripper.urdf/meshes/4C2_Link3.STL"/>
    <mesh name="eg2_link4" file="../../third_party/rm_models/thirdparty/Two-finger Electric Gripper.urdf/meshes/4C2_Link4.STL"/>
    <mesh name="eg2_link5" file="../../third_party/rm_models/thirdparty/Two-finger Electric Gripper.urdf/meshes/4C2_Link5.STL"/>
    <mesh name="eg2_link6" file="../../third_party/rm_models/thirdparty/Two-finger Electric Gripper.urdf/meshes/4C2_Link6.STL"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <body name="base_link" pos="0 0 0" childclass="rm65">
      <geom class="rm65/visual" mesh="rm65_base_link"/>
      <geom class="rm65/collision" mesh="rm65_base_link"/>

      <body name="link_1" pos="0 0 0.2405">
        <joint name="joint_1" type="hinge" axis="0 0 1" range="-3.106 3.106"/>
        <geom class="rm65/visual" mesh="rm65_link_1"/>
        <geom class="rm65/collision" mesh="rm65_link_1"/>

        <body name="link_2" pos="0 0 0" quat="0.499998 0.500000 -0.500000 0.500002">
          <joint name="joint_2" type="hinge" axis="0 0 1" range="-2.2689 2.2689"/>
          <geom class="rm65/visual" mesh="rm65_link_2"/>
          <geom class="rm65/collision" mesh="rm65_link_2"/>

          <body name="link_3" pos="0.256 0 0" quat="0.707105 0 0 0.707108">
            <joint name="joint_3" type="hinge" axis="0 0 1" range="-2.356 2.356"/>
            <geom class="rm65/visual" mesh="rm65_link_3"/>
            <geom class="rm65/collision" mesh="rm65_link_3"/>

            <body name="link_4" pos="0 -0.21 0" quat="0.707105 0.707108 0 0">
              <joint name="joint_4" type="hinge" axis="0 0 1" range="-3.106 3.106"/>
              <geom class="rm65/visual" mesh="rm65_link_4"/>
              <geom class="rm65/collision" mesh="rm65_link_4"/>

              <body name="link_5" pos="0 0 0" quat="0.707105 -0.707108 0 0">
                <joint name="joint_5" type="hinge" axis="0 0 1" range="-2.234 2.234"/>
                <geom class="rm65/visual" mesh="rm65_link_5"/>
                <geom class="rm65/collision" mesh="rm65_link_5"/>

                <body name="link_6" pos="0 -0.1725 0" quat="0.707105 0.707108 0 0">
                  <joint name="joint_6" type="hinge" axis="0 0 1" range="-6.28 6.28"/>
                  <geom class="rm65/visual" mesh="rm65_link_6"/>
                  <geom class="rm65/collision" mesh="rm65_link_6"/>

                  <!-- ================================================= -->
                  <!-- Realman EG2-4C2 gripper (simplified 2-finger model)-->
                  <!-- Uses the official base & finger meshes; the 4-bar   -->
                  <!-- parallel linkage is approximated as two independent -->
                  <!-- revolute fingers pivoting inward/outward.           -->
                  <!-- ================================================= -->
                  <body name="eg2_base" pos="0 0 0" quat="0.7071068 0 0 0.7071068" childclass="eg2">
                    <inertial pos="0 0 0.038" mass="0.073"
                      diaginertia="5.1e-05 6.1e-05 1.9e-05"/>
                    <geom class="eg2/visual" mesh="eg2_base"/>
                    <geom class="eg2/collision" mesh="eg2_base"/>

                    <!-- Right finger (visual: link1 mesh; tip geom: link5) -->
                    <body name="eg2_right_finger" pos="-0.04 -0.009 0.079">
                      <inertial pos="0.02 0 0.03" mass="0.013" diaginertia="5e-6 5e-6 2e-6"/>
                      <joint name="4C2_Joint1" class="eg2_driver_pos"/>
                      <geom class="eg2/visual" mesh="eg2_link1"/>
                      <geom class="eg2/collision" mesh="eg2_link1"/>
                      <!-- Fingertip pad (link5 mesh rigidly attached at its kinematic offset) -->
                      <geom class="eg2/visual" mesh="eg2_link5" pos="0.0223 0.003 0.035591"/>
                      <geom class="eg2/collision" mesh="eg2_link5" pos="0.0223 0.003 0.035591"/>
                    </body>

                    <!-- Left finger (mirrored) -->
                    <body name="eg2_left_finger" pos="0.04 -0.009 0.079">
                      <inertial pos="-0.02 0 0.03" mass="0.013" diaginertia="5e-6 5e-6 2e-6"/>
                      <joint name="4C2_Joint4" class="eg2_driver_neg"/>
                      <geom class="eg2/visual" mesh="eg2_link4"/>
                      <geom class="eg2/collision" mesh="eg2_link4"/>
                      <geom class="eg2/visual" mesh="eg2_link6" pos="-0.0223 0.003 0.035591"/>
                      <geom class="eg2/collision" mesh="eg2_link6" pos="-0.0223 0.003 0.035591"/>
                    </body>
                  </body>

                  <!-- EE site at gripper fingertip pinch point -->
                  <site name="rm65_ee_site" pos="0 0 0.145" quat="1 0 0 0"/>

                  <!-- Wrist camera: mounted on flange, looks along tool axis (link_6 +Z).
                       Press [ or ] in MuJoCo viewer to cycle to this camera. -->
                  <camera name="wrist_cam" pos="0 0.05 0.0" euler="3.14159 0 0"
                    fovy="70" resolution="640 480"/>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- Scene cameras: press [ or ] in the viewer to cycle -->
    <camera name="scene_cam" pos="1.2 -0.8 0.9" xyaxes="0.6 0.8 0 -0.3 0.22 0.9" fovy="45"/>

    <body name="target_cube" pos="0.4 0 0.018">
      <freejoint/>
      <geom name="target_cube_geom" type="box" size="0.018 0.018 0.018"
        rgba="0.2 0.6 0.9 1" contype="1" conaffinity="1" density="50"
        friction="2.0 0.3 0.2"
        solref="0.01 1.5" solimp="0.95 0.99 0.001"/>
    </body>
  </worldbody>

  <equality>
    <!-- Left finger mirrors right: Joint4 = -Joint1 -->
    <joint joint1="4C2_Joint4" joint2="4C2_Joint1" polycoef="0 -1 0 0 0"
      solimp="0.95 0.99 0.001" solref="0.005 1"/>
  </equality>

  <tendon>
    <!-- Gripper tendon (single-DOF, tendon actuator skipped by IK apply_control) -->
    <fixed name="eg2_tendon">
      <joint joint="4C2_Joint1" coef="1"/>
    </fixed>
  </tendon>

  <actuator>
    <!-- RM65 arm (ctrlrange mirrors each joint's physical range) -->
    <position class="rm65_actuator" name="joint_1" joint="joint_1" ctrlrange="-3.106 3.106"/>
    <position class="rm65_actuator" name="joint_2" joint="joint_2" ctrlrange="-2.2689 2.2689"/>
    <position class="rm65_actuator" name="joint_3" joint="joint_3" ctrlrange="-2.356 2.356"/>
    <position class="rm65_actuator" name="joint_4" joint="joint_4" ctrlrange="-3.106 3.106"/>
    <position class="rm65_actuator" name="joint_5" joint="joint_5" ctrlrange="-2.234 2.234"/>
    <position class="rm65_actuator" name="joint_6" joint="joint_6" ctrlrange="-6.28 6.28"/>
    <!-- EG2-4C2 gripper: ctrl=0 closed, ctrl=0.82 open (normally-closed).
         Inversion handled via pinch_inverted config flag in teleop_sim.py.
         biastype=affine enables the PD-like feedback from biasprm. -->
    <general name="fingers_actuator" tendon="eg2_tendon"
      ctrlrange="0 0.82" forcerange="-50 50" biastype="affine"
      gainprm="200 0 0" biasprm="0 -200 -20"/>
  </actuator>
</mujoco>
